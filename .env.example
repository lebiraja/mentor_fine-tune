# ClarityMentor v3 configuration
# Copy to .env and fill in. Everything runs locally — no values leave this machine.

# Hugging Face token — only needed once, for `make models` (model downloads).
# ROTATE THIS if it was ever committed or shared.
HF_TOKEN=

# Backend
HOST=0.0.0.0
PORT=2323
DEBUG=false

# llama.cpp server (set automatically inside docker; override for local dev)
LLM_BASE_URL=http://localhost:2380/v1
LLM_MODEL=qwen3-4b-instruct-2507
LLM_MAX_TOKENS=400
LLM_TEMPERATURE=0.7
LLM_CONTEXT_TOKENS=8192

# STT (faster-whisper)
STT_MODEL=large-v3-turbo
STT_DEVICE=cuda
STT_COMPUTE_TYPE=int8

# Voice — English
TTS_VOICE=af_heart
TTS_SPEED=1.0

# Voice — Tamil (set false to disable)
PIPER_TAMIL_ENABLED=true

# VAD turn-taking (seconds)
VAD_THRESHOLD=0.5
VAD_MIN_SPEECH_S=0.25
VAD_END_SILENCE_S=0.9          # higher = tolerate longer mid-sentence pauses

# Echo / feedback handling (laptop speakers without headphones)
# ALLOW_BARGE_IN=false: ignore the mic while the assistant speaks so it never hears
#   itself and loops. Set true ONLY if you wear headphones and want to interrupt it.
ALLOW_BARGE_IN=false
ECHO_TAIL_S=0.8               # extra silence after speech before listening resumes

# Memory architecture
MEMORY_ENABLED=true
MEMORY_HYBRID_RETRIEVAL=true
MEMORY_RECENT_MESSAGE_LIMIT=8
MEMORY_SEMANTIC_LIMIT=8
MEMORY_CONSOLIDATE_ON_SWITCH=true

# Semantic memory graph (optional; use docker compose --profile memory ...)
SEMANTIC_MEMORY_ENABLED=false
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=clarity-memory-dev
NEO4J_DATABASE=neo4j
NEO4J_CONNECT_TIMEOUT_S=5.0

# Storage
DB_PATH=/app/data/clarity.db
